{
  "profile_id": "custom",
  "name": "Custom",
  "system": false,
  "version": "1.0.0",
  "description": "Editable free-form profile for medicine, law, sales, design, development, education, operations, and any custom domain.",
  "domain_examples": [
    "medicine",
    "law",
    "sales",
    "design",
    "development",
    "education",
    "operations"
  ],
  "roles": [
    "specialist",
    "operator",
    "analyst",
    "manager",
    "lead"
  ],
  "grades": [
    "junior",
    "middle",
    "senior",
    "lead"
  ],
  "skills": [
    "domain_knowledge",
    "communication",
    "analysis",
    "execution",
    "quality_control",
    "planning"
  ],
  "task_types": [
    "task",
    "review",
    "analysis",
    "support",
    "research",
    "delivery"
  ],
  "feature_groups": {
    "employee": [
      {
        "name": "availability_score",
        "type": "numeric",
        "required": true,
        "min": 0,
        "max": 1
      },
      {
        "name": "current_workload",
        "type": "numeric",
        "required": true,
        "min": 0,
        "max": 1
      },
      {
        "name": "fatigue_score",
        "type": "numeric",
        "required": true,
        "min": 0,
        "max": 1
      },
      {
        "name": "learning_goals",
        "type": "skill_list",
        "required": false
      },
      {
        "name": "notes",
        "type": "text",
        "required": false
      }
    ],
    "task": [
      {
        "name": "priority",
        "type": "categorical",
        "required": true,
        "values": [
          "low",
          "medium",
          "high",
          "critical"
        ]
      },
      {
        "name": "complexity",
        "type": "numeric",
        "required": true,
        "min": 1,
        "max": 10
      },
      {
        "name": "estimated_hours",
        "type": "numeric",
        "required": true,
        "min": 0.5,
        "max": 240
      },
      {
        "name": "required_skills",
        "type": "skill_list",
        "required": true
      },
      {
        "name": "is_learning_task",
        "type": "boolean",
        "required": false
      }
    ],
    "outcome": [
      {
        "name": "quality_score",
        "type": "numeric",
        "required": true,
        "min": 0,
        "max": 1
      },
      {
        "name": "deadline_status",
        "type": "categorical",
        "required": true,
        "values": [
          "early",
          "on_time",
          "late",
          "missed"
        ]
      },
      {
        "name": "outcome_label",
        "type": "categorical",
        "required": true,
        "values": [
          "success",
          "good",
          "acceptable",
          "late",
          "failed",
          "rework"
        ]
      },
      {
        "name": "was_rework_needed",
        "type": "boolean",
        "required": true
      }
    ]
  }
}